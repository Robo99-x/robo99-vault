<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>com.robo99.weekly_market_upgrade</string>
  <key>ProgramArguments</key>
  <array>
    <string>/usr/bin/env</string>
    <string>bash</string>
    <string>-lc</string>
    <string>cd /Users/robo99/robo99_hq/scripts && uv run python weekly_market_upgrade.py</string>
  </array>
  <key>StartCalendarInterval</key>
  <dict>
    <key>Weekday</key>
    <integer>2</integer>
    <key>Hour</key>
    <integer>6</integer>
    <key>Minute</key>
    <integer>0</integer>
  </dict>
  <key>StandardOutPath</key>
  <string>/Users/robo99/robo99_hq/alerts/weekly_upgrade.out.log</string>
  <key>StandardErrorPath</key>
  <string>/Users/robo99/robo99_hq/alerts/weekly_upgrade.err.log</string>
  <key>RunAtLoad</key>
  <false/>
</dict>
</plist>
